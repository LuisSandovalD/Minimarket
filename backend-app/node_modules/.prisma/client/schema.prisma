generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 🔐 ENUMERACIONES (ENUMS)
// ==========================================

enum Role {
  ADMIN // Administrador de la plataforma
  MANAGER // Gerente de sucursal/empresa
  SUPERVISOR // Supervisor (nuevo: nivel intermedio)
  EMPLOYEE // Empleado/Vendedor
  VIEWER // Solo lectura
}

enum PaymentMethod {
  CASH // Efectivo
  CARD // Tarjeta
  CHECK // Cheque
  TRANSFER // Transferencia bancaria
  WALLET // Billetera digital
}

enum PaymentStatus {
  PENDING // Pendiente
  COMPLETED // Completado
  FAILED // Fallido (nuevo)
  CANCELLED // Cancelado
  REFUNDED // Reembolsado
  PARTIAL // Pago parcial (nuevo)
}

enum SaleStatus {
  DRAFT // Borrador
  PENDING // Pendiente (nuevo)
  COMPLETED // Completado
  CANCELLED // Cancelado
  RETURNED // Devuelto
  ARCHIVED // Archivado (nuevo)
}

enum PurchaseStatus {
  DRAFT // Borrador (nuevo)
  PENDING // Pendiente (nuevo)
  RECEIVED // Recibido (nuevo)
  COMPLETED // Completado
  CANCELLED // Cancelado
  ARCHIVED // Archivado (nuevo)
}

enum NotificationType {
  EXPIRING_PRODUCT // Producto próximo a vencer
  LOW_STOCK // Stock bajo
  SYSTEM_ALERT // Alerta del sistema
  PURCHASE_READY // Compra lista
  USER_ALERT // Alerta de usuario
  INVENTORY_MISMATCH // Discrepancia de inventario (nuevo)
  PAYMENT_OVERDUE // Pago vencido (nuevo)
}

enum AuditAction {
  CREATE // Crear
  UPDATE // Actualizar
  DELETE // Eliminar
  SOFT_DELETE // Eliminación lógica
  LOGIN // Inicio de sesión
  LOGOUT // Cierre de sesión
  EXPORT // Exportar
  IMPORT // Importar
  RESTORE // Restaurar (nuevo)
}

enum TicketStatus {
  OPEN // Abierto
  IN_PROGRESS // En progreso
  WAITING // Esperando respuesta (nuevo)
  RESOLVED // Resuelto
  CLOSED // Cerrado
  REOPENED // Reabierto (nuevo)
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum UnitType {
  LITER // Litro
  HALF_LITER // Medio litro
  QUARTER_LITER // Cuarto de litro
  MILLILITER // Mililitro
  GRAM // Gramo
  KILOGRAM // Kilogramo
  UNIT // Unidad/Pieza
  BOX // Caja
  PACK // Paquete
  DOZEN // Docena
  METER // Metro (nuevo)
  SQUARE_METER // Metro cuadrado (nuevo)
}

// ==========================================
// 🏢 COMPANY (EMPRESA)
// ==========================================

model Company {
  id      Int     @id @default(autoincrement())
  name    String  @unique @db.VarChar(255)
  slug    String  @unique @db.VarChar(100)
  ruc     String? @unique @db.VarChar(20)
  address String? @db.VarChar(500)
  phone   String? @db.VarChar(20)
  email   String? @db.VarChar(255)
  logo    String? @db.VarChar(500)
  website String? @db.VarChar(255)

  // Información fiscal
  taxId               String? @unique @db.VarChar(50)
  legalRepresentative String? @db.VarChar(255)

  isActive         Boolean @default(true)
  isDeleted        Boolean @default(false) // Soft delete
  subscriptionTier String  @default("FREE") @db.VarChar(50)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Para soft delete

  // Relaciones
  users            User[]
  branches         Branch[]
  categories       Category[]
  products         Product[]
  sales            Sale[]
  purchases        Purchase[]
  inventory        Inventory[]
  notifications    Notification[]
  auditLogs        AuditLog[]
  supportTickets   SupportTicket[]
  configuration    Configuration?
  paymentMethods   PaymentMethod_DB[]
  units            Unit[]
  inventoryHistory InventoryHistory[]

  // Índices
  @@index([isActive])
  @@index([isDeleted])
  @@index([subscriptionTier])
}

// ==========================================
// 🏬 BRANCH (SUCURSAL)
// ==========================================

model Branch {
  id   Int     @id @default(autoincrement())
  name String  @db.VarChar(255)
  slug String  @db.VarChar(100)
  code String? @db.VarChar(20)

  address    String  @db.VarChar(500)
  phone      String? @db.VarChar(20)
  email      String? @db.VarChar(255)
  city       String? @db.VarChar(100)
  state      String? @db.VarChar(100) // Nuevo: departamento
  country    String? @db.VarChar(100)
  postalCode String? @db.VarChar(20) // Nuevo

  isActive  Boolean @default(true)
  isDeleted Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  companyId Int
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Relaciones
  users     User[]
  inventory Inventory[]
  sales     Sale[]
  purchases Purchase[]
  auditLogs AuditLog[]

  @@unique([slug, companyId])
  @@unique([name, companyId])
  @@unique([code, companyId])
  @@index([companyId])
  @@index([isActive])
  @@index([isDeleted])
}

// ==========================================
// 👤 USER (USUARIO)
// ==========================================

model User {
  id       Int    @id @default(autoincrement())
  name     String @db.VarChar(255)
  email    String @unique @db.VarChar(255)
  password String @db.VarChar(255)
  slug     String @db.VarChar(100)

  role   Role    @default(EMPLOYEE)
  phone  String? @db.VarChar(20)
  avatar String? @db.VarChar(500)

  // Autenticación
  isActive      Boolean   @default(true)
  isDeleted     Boolean   @default(false)
  lastLogin     DateTime?
  loginAttempts Int       @default(0) // Nuevo: para prevenir ataques de fuerza bruta
  lockedUntil   DateTime? // Nuevo: bloqueo temporal

  // 2FA
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String? @db.VarChar(255)
  backupCodes      String? // JSON array de códigos de respaldo (nuevo)

  // Auditoría de usuario
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  companyId Int
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  branchId Int?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  // Relaciones
  sales           Sale[]          @relation("UserSales")
  purchases       Purchase[]      @relation("UserPurchases")
  notifications   Notification[]
  auditLogs       AuditLog[]      @relation("UserAudits")
  supportTickets  SupportTicket[] @relation("UserTickets")
  assignedTickets SupportTicket[] @relation("AssignedTickets")
  ticketComments  TicketComment[]

  @@unique([slug, companyId])
  @@index([companyId])
  @@index([branchId])
  @@index([isActive])
  @@index([isDeleted])
  @@index([role])
}

// ==========================================
// 📏 UNIT (UNIDAD DE MEDIDA)
// ==========================================

model Unit {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(100) // Litro, Medio Litro, etc.
  abbreviation String   @db.VarChar(20) // L, ML, KG, etc.
  type         UnitType

  // Conversión
  conversionFactor Decimal @default(1) @db.Decimal(10, 4) // Nuevo: para conversiones
  baseUnit         Int? // Nuevo: referencia a unidad base

  isActive  Boolean @default(true)
  companyId Int
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  products Product[]

  @@unique([abbreviation, companyId])
  @@unique([name, companyId])
  @@index([companyId])
  @@index([isActive])
}

// ==========================================
// 📁 CATEGORY (CATEGORÍA)
// ==========================================

model Category {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(255)
  slug        String  @db.VarChar(100)
  description String? @db.VarChar(500)
  icon        String? @db.VarChar(500)

  // Jerarquía
  parentId Int? // Nuevo: categorías anidadas
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryHierarchy")

  isActive  Boolean @default(true)
  isDeleted Boolean @default(false)

  companyId Int
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  products Product[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([slug, companyId])
  @@unique([name, companyId])
  @@index([companyId])
  @@index([parentId])
  @@index([isActive])
}

// ==========================================
// 🍎 PRODUCT (PRODUCTO)
// ==========================================

model Product {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(255)
  slug        String  @db.VarChar(100)
  description String? @db.Text
  sku         String? @db.VarChar(50)
  barcode     String? @db.VarChar(50)

  // Precios
  purchasePrice Decimal @db.Decimal(10, 2)
  salePrice     Decimal @db.Decimal(10, 2)
  costPrice     Decimal @db.Decimal(10, 2) // Nuevo: precio de costo para margen

  // Stock
  stock    Int  @default(0)
  minStock Int  @default(5)
  maxStock Int? // Nuevo: stock máximo

  // Caducidad
  expirationDate     DateTime?
  batchNumber        String?   @db.VarChar(100)
  requiresExpiration Boolean   @default(false) // Nuevo: si requiere fecha de vencimiento

  // Estado
  isActive   Boolean @default(true)
  isDeleted  Boolean @default(false)
  isFeatured Boolean @default(false) // Nuevo

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  companyId Int
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  unitId Int
  unit   Unit @relation(fields: [unitId], references: [id])

  // Relaciones
  inventory        Inventory[]
  saleDetails      SaleDetail[]
  purchaseDetails  PurchaseDetail[]
  notifications    Notification[]
  inventoryHistory InventoryHistory[]

  @@unique([slug, companyId])
  @@unique([sku, companyId])
  @@index([companyId])
  @@index([categoryId])
  @@index([expirationDate])
  @@index([isActive])
  @@index([isDeleted])
  @@index([minStock, stock]) // Índice compuesto para bajo stock
}

// ==========================================
// 📦 INVENTORY (INVENTARIO)
// ==========================================

model Inventory {
  id            Int @id @default(autoincrement())
  stock         Int @default(0)
  reservedStock Int @default(0) // Nuevo: stock reservado (pendientes)
  damagedStock  Int @default(0) // Nuevo: stock dañado

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  companyId Int
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  lastUpdated DateTime @updatedAt
  createdAt   DateTime @default(now())

  // Relaciones
  movements InventoryHistory[]

  @@unique([productId, branchId])
  @@index([branchId])
  @@index([companyId])
  @@index([stock]) // Nuevo: para queries de bajo stock
}

// ==========================================
// 📊 INVENTORY HISTORY (NUEVO: Historial de Inventario)
// ==========================================

model InventoryHistory {
  id            Int     @id @default(autoincrement())
  type          String  @db.VarChar(50) // SALE, PURCHASE, ADJUSTMENT, RETURN, etc.
  quantity      Int
  previousStock Int
  newStock      Int
  reason        String? @db.VarChar(255)
  reference     String? @db.VarChar(100) // Número de venta, compra, etc.

  createdAt DateTime @default(now())

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  branchId  Int
  inventory Inventory @relation(fields: [branchId], references: [id], onDelete: Cascade)

  companyId Int
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([branchId])
  @@index([companyId])
  @@index([createdAt])
  @@index([type])
}

// ==========================================
// 💳 PAYMENT METHOD_DB (MÉTODO DE PAGO)
// ==========================================

model PaymentMethod_DB {
  id   Int           @id @default(autoincrement())
  name String        @db.VarChar(100) // Efectivo, Tarjeta, etc.
  type PaymentMethod

  // Configuración de método
  accountNumber String? @db.VarChar(50)
  accountHolder String? @db.VarChar(255)
  isActive      Boolean @default(true)

  companyId Int
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  payments Payment[]

  @@unique([type, companyId])
  @@index([companyId])
  @@index([isActive])
}

// ==========================================
// 💰 SALE (VENTA)
// ==========================================

model Sale {
  id         Int     @id @default(autoincrement())
  saleNumber String  @unique @db.VarChar(50)
  total      Decimal @db.Decimal(10, 2)
  subtotal   Decimal @db.Decimal(10, 2)
  tax        Decimal @default(0) @db.Decimal(10, 2)
  discount   Decimal @default(0) @db.Decimal(10, 2)

  status SaleStatus @default(COMPLETED)
  notes  String?    @db.VarChar(500)

  // Cliente
  customerName  String? @db.VarChar(255) // Nuevo
  customerPhone String? @db.VarChar(20) // Nuevo
  customerEmail String? @db.VarChar(255) // Nuevo

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sellerId Int
  seller   User @relation("UserSales", fields: [sellerId], references: [id])

  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id])

  companyId Int
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Relaciones
  details  SaleDetail[]
  payments Payment[]

  @@index([companyId])
  @@index([branchId])
  @@index([createdAt])
  @@index([sellerId])
  @@index([status])
  @@index([saleNumber])
}

// ==========================================
// 🧾 SALE DETAIL (DETALLE DE VENTA)
// ==========================================

model SaleDetail {
  id       Int     @id @default(autoincrement())
  quantity Int
  price    Decimal @db.Decimal(10, 2)
  subtotal Decimal @db.Decimal(10, 2)
  discount Decimal @default(0) @db.Decimal(10, 2)
  tax      Decimal @default(0) @db.Decimal(10, 2) // Nuevo

  saleId Int
  sale   Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
}

// ==========================================
// 🛒 PURCHASE (COMPRA)
// ==========================================

model Purchase {
  id             Int     @id @default(autoincrement())
  purchaseNumber String  @unique @db.VarChar(50)
  total          Decimal @db.Decimal(10, 2)
  subtotal       Decimal @db.Decimal(10, 2)
  tax            Decimal @default(0) @db.Decimal(10, 2)

  status PurchaseStatus @default(COMPLETED) // Mejorado: enum separado
  notes  String?        @db.VarChar(500)

  // Proveedor
  supplierName  String? @db.VarChar(255) // Nuevo
  supplierPhone String? @db.VarChar(20)
  supplierEmail String? @db.VarChar(255)
  supplierRuc   String? @db.VarChar(50)

  // Fechas
  expectedDelivery DateTime? // Nuevo
  actualDelivery   DateTime? // Nuevo

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyerId Int
  buyer   User @relation("UserPurchases", fields: [buyerId], references: [id])

  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id])

  companyId Int
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Relaciones
  details  PurchaseDetail[]
  payments Payment[]
  discount Decimal          @default(0) @db.Decimal(10, 2)

  @@index([companyId])
  @@index([branchId])
  @@index([createdAt])
  @@index([status])
  @@index([purchaseNumber])
}

// ==========================================
// 📦 PURCHASE DETAIL (DETALLE DE COMPRA)
// ==========================================

model PurchaseDetail {
  id       Int     @id @default(autoincrement())
  quantity Int
  price    Decimal @db.Decimal(10, 2)
  subtotal Decimal @db.Decimal(10, 2)
  tax      Decimal @default(0) @db.Decimal(10, 2) // Nuevo

  purchaseId Int
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  @@index([purchaseId])
  @@index([productId])
}

// ==========================================
// 💵 PAYMENT (PAGO)
// ==========================================

model Payment {
  id     Int     @id @default(autoincrement())
  amount Decimal @db.Decimal(10, 2)

  status        PaymentStatus    @default(PENDING)
  paymentMethod Int
  method        PaymentMethod_DB @relation(fields: [paymentMethod], references: [id])

  reference String? @db.VarChar(100)
  notes     String? @db.VarChar(500)

  // Información de pago
  transactionId String?   @db.VarChar(100) // Nuevo: ID de transacción
  paidAt        DateTime? // Nuevo: fecha de pago real
  dueDate       DateTime? // Nuevo: fecha de vencimiento

  saleId Int?
  sale   Sale? @relation(fields: [saleId], references: [id], onDelete: SetNull)

  purchaseId Int?
  purchase   Purchase? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([saleId])
  @@index([purchaseId])
  @@index([status])
  @@index([paidAt])
}

// ==========================================
// 🔔 NOTIFICATION (NOTIFICACIÓN)
// ==========================================

model Notification {
  id      Int              @id @default(autoincrement())
  title   String           @db.VarChar(255)
  message String           @db.Text
  type    NotificationType

  isRead Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId Int?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  companyId Int
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@index([companyId])
  @@index([createdAt])
}

// ==========================================
// 📋 AUDIT LOG (REGISTRO DE AUDITORÍA)
// ==========================================

model AuditLog {
  id          Int         @id @default(autoincrement())
  action      AuditAction
  entityType  String      @db.VarChar(100) // "User", "Product", "Sale", etc.
  entityId    Int
  description String?     @db.VarChar(500) // Nuevo: descripción legible

  oldValues Json? // JSON con valores anteriores
  newValues Json? // JSON con valores nuevos

  ipAddress String? @db.VarChar(50)
  userAgent String? @db.VarChar(500)

  createdAt DateTime @default(now())

  userId Int?
  user   User? @relation("UserAudits", fields: [userId], references: [id], onDelete: SetNull)

  branchId Int?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  companyId Int
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entityType])
  @@index([companyId])
  @@index([createdAt])
  @@index([action])
}

// ==========================================
// 🛠️ SUPPORT TICKET (TICKET DE SOPORTE)
// ==========================================

model SupportTicket {
  id           Int    @id @default(autoincrement())
  ticketNumber String @unique @db.VarChar(50)
  title        String @db.VarChar(255)
  description  String @db.Text

  status   TicketStatus   @default(OPEN)
  priority TicketPriority @default(MEDIUM)

  attachments String? // JSON array de URLs (nuevo)

  // Resolución
  resolutionNotes String? @db.Text // Nuevo

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?

  userId Int
  user   User @relation("UserTickets", fields: [userId], references: [id], onDelete: Cascade)

  assignedTo   Int?
  assignedUser User? @relation("AssignedTickets", fields: [assignedTo], references: [id], onDelete: SetNull)

  companyId Int
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Relaciones
  comments TicketComment[]

  @@index([status])
  @@index([priority])
  @@index([companyId])
  @@index([userId])
  @@index([ticketNumber])
}

// ==========================================
// 💬 TICKET COMMENT (COMENTARIO DE TICKET)
// ==========================================

model TicketComment {
  id          Int     @id @default(autoincrement())
  message     String  @db.Text
  attachments String? // JSON array (nuevo)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ticketId Int
  ticket   SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([userId])
}

// ==========================================
// ⚙️ CONFIGURATION (CONFIGURACIÓN)
// ==========================================

model Configuration {
  id Int @id @default(autoincrement())

  // General
  companyName String? @db.VarChar(255)
  logo        String? @db.VarChar(500)
  theme       String  @default("light") @db.VarChar(50)
  language    String  @default("es") @db.VarChar(10)

  // Fiscal
  taxRate           Decimal @default(0) @db.Decimal(5, 2)
  currency          String  @default("PEN") @db.VarChar(10)
  defaultTaxEnabled Boolean @default(true) // Nuevo

  // Notificaciones
  notifyLowStock    Boolean @default(true)
  lowStockThreshold Int     @default(5)
  notifyExpiring    Boolean @default(true)
  expiringDaysAlert Int     @default(30)

  // Seguridad
  requireTwoFactor      Boolean @default(false)
  sessionTimeout        Int     @default(3600) // segundos
  passwordMinLength     Int     @default(8)
  passwordExpiresDays   Int? // Nuevo: días antes de expirar contraseña
  requirePasswordChange Boolean @default(false) // Nuevo

  // Sistema
  allowMultipleLogins Boolean @default(true)
  autoBackup          Boolean @default(true)
  backupFrequency     String  @default("DAILY") @db.VarChar(50)
  maxLoginAttempts    Int     @default(5) // Nuevo

  // Acceso
  allowExport Boolean @default(true) // Nuevo
  allowImport Boolean @default(true) // Nuevo

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId Int     @unique
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}
