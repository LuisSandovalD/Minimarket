# URL de conexión a la base de datos PostgreSQL
# Formato: postgresql://usuario:password@host:puerto/base_de_datos
# En este caso:
# usuario: ts_admin
# contraseña: ts_secret
# host: postgres (nombre del contenedor o servicio en Docker)
# puerto: 5432 (puerto por defecto de PostgreSQL)
# base de datos: tienda_sucursales
DATABASE_URL=postgresql://ts_admin:ts_secret@postgres:5432/tienda_sucursales

# Clave secreta para firmar los tokens JWT (autenticación)
# IMPORTANTE: en producción debe ser más segura y no exponerse
JWT_SECRET=super_secret_jwt_key

# Tiempo de expiración del token JWT
# "7d" significa que el token expira en 7 días
JWT_EXPIRES_IN=7d

# Puerto en el que se ejecuta la aplicación
PORT=4000

# Entorno de ejecución de la app
# development → desarrollo (logs detallados, debugging)
# production → producción (optimizado, más seguro)
NODE_ENV=development